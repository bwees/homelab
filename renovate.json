{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "baseBranchPatterns": ["main"],
  "docker-compose": {
    "managerFilePatterns": ["/^deploy\\/compose\\/.*\\.ya?ml$/"],
    "digest": {
      "enabled": false
    }
  },
  "flux": {
    "managerFilePatterns": ["/^kubernetes\\/.+\\.ya?ml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Container image tags in Flux HelmRelease values (app-template image.repository/tag pairs)",
      "managerFilePatterns": ["/^kubernetes\\/.+\\.ya?ml$/"],
      "matchStrings": [
        "image:\\s+repository:\\s+(?<depName>\\S+)\\s+tag:\\s+[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Tag-only image overrides annotated with a renovate comment (e.g. immich)",
      "managerFilePatterns": ["/^kubernetes\\/.+\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+tag:\\s+[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },

    // Ignore rules
    {
      "description": "Linuxserver ignore qBittorrent old ubuntu versions. Originally tagged based on the ubuntu image they based on which triggers renovatebot.",
      "matchPackageNames": ["linuxserver/qbittorrent"],
      "allowedVersions": "<12.0.0"
    },
    {
      "description": "Linuxserver ignore jellyfin old year based tags",
      "matchPackageNames": ["linuxserver/jellyfin"],
      "allowedVersions": "<2020.0.0"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "docker.io/valkey/valkey",
        "ghcr.io/immich-app/postgres"
      ],
      "matchFileNames": [
        "deploy/compose/lab/immich.yml",
        "deploy/compose/home/immich.yml",
        "deploy/compose/stepien/immich.yml"
      ],
      "enabled": false
    },

    // Groups
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/immich-app/immich-server",
        "ghcr.io/immich-app/immich-machine-learning"
      ],
      "groupName": "immich"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/haveagitgat/tdarr",
        "haveagitgat/tdarr_node"
      ],
      "groupName": "tdarr"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["henrygd/beszel", "henrygd/beszel-agent"],
      "groupName": "beszel"
    },
    {
      "matchDatasources": ["docker", "dockerfile"],
      "matchPackageNames": ["n8nio/runners", "n8nio/n8n"],
      "groupName": "n8n"
    }
  ],
  "ignoreTests": true
}
